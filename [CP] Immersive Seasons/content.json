{
    // Note: Edit only Config, DynamicTokens, Include Actions, and Load Actions.
    "Format": "2.9.0",
    "$schema": "https://smapi.io/schemas/content-patcher.json",
    // --- Configuration ---
    "ConfigSchema": {},
    // --- Dynamic Tokens ---
    "DynamicTokens": [
        /* for immersive seasons, not totems
        { //season phase
            "Name": "Phase",
            "Value": "Early",
            "When": {
                "Day": "{{Range: 1, 7}}",
            },
        },
        { //season phase
            "Name": "Phase",
            "Value": "Mid",
            "When": {
                "Day": "{{Range: 8, 21}}",
            },
        },
        { //season phase
            "Name": "Phase",
            "Value": "Late",
            "When": {
                "Day": "{{Range: 22, 28}}",
            },
        },
        */
        { // Totem Name Color
            "Name": "TotemNameColor",
            "Value": "44, 32, 138" // RGB Value
        },
    ],
    "Changes": [
        // --- Included Patches ---
        { // Buffs + Powers
            "LogName": "Buffs and Powers",
            "Action": "Include",
            "FromFile": "code/BuffsAndPowers.json"
        },
        { // Forage
            "LogName": "Forage",
            "Action": "Include",
            "FromFile": "code/Forage.json"
        },
        { // Gifts
            "LogName": "Gifts",
            "Action": "Include",
            "FromFile": "code/Gifts.json"
        },
        { // CRAFTING RECIPES
            "LogName": "Crafting Recipes",
            "Action": "Include",
            "FromFile": "code/CraftingRecipes.json"
        },
        { // Objects
            "LogName": "Objects",
            "Action": "Include",
            "FromFile": "code/Objects.json"
        },
        /* 
        TODO: Experimental, uncomment when ready
        { // Spawns
            "LogName": "Spawns",
            "Action": "Include",
            "FromFile": "code/Spawns.json"
        },
        */
        { // Triggers
            "LogName": "Triggers",
            "Action": "Include",
            "FromFile": "code/Triggers.json"
        },
        // --- Asset Image Loaders ---
        {
            "Action": "Load",
            "Target": "Mods/{{ModId}}/assets/images/WeatherTotems",
            "FromFile": "assets/images/WeatherTotems.png"
        },
        {
            "Action": "Load",
            "Target": "Mods/{{ModId}}/assets/images/Forage",
            "FromFile": "assets/images/Forage.png"
        },
        {
            "Action": "Load",
            "Target": "Mods/{{ModId}}/assets/images/Buffs",
            "FromFile": "assets/images/Buffs.png"
        },
    ]
}