{
	"$schema": "https://smapi.io/schemas/content-patcher.json",
	"Changes": [
		{
			"Action": "EditData",
			"Target": "Data/TriggerActions",
			"Entries": {
				// --- Prismatic Crystal Fruit ---
				"{{ModId}}_Trigger.HadPrismaticCrystalFruit": {
					"Id": "{{ModId}}_Trigger.HadPrismaticCrystalFruit",
					"Trigger": "spacechase0.SpaceCore_OnItemEaten",
					"Condition": "ITEM_ID Input (O){{ModId}}_Item.PrismaticCrystalFruit",
					"Actions": [
						"AddMail current {{ModId}}_Mail.HadPrismaticCrystalFruit received",
						"Spiderbuttons.BETAS_Message \"{{i18n: i18n_String.PrismaticCrystalFruitEaten}}\" true",
						"Spiderbuttons.BETAS_PlaySound stardrop",
					],
					"MarkActionApplied": false, // TODO: Remove later, make inedible after first consumption
				},
				"{{ModId}}_Trigger.PrismaticCrystalFruitPower": {
					"Id": "{{ModId}}_Trigger.PrismaticCrystalFruitPower",
					"Trigger": "DayStarted",
					"Condition": "PLAYER_HAS_MAIL current {{ModId}}_Mail.HadPrismaticCrystalFruit",
					"Action": "AddBuff {{ModId}}_Buff.PrismaticCrystalFruit -2",
					"MarkActionApplied": false,
				},
				// --- Totems ---
				// Rain Totem
				"{{ModId}}_Trigger.RainTotem": {
					"Id": "{{ModId}}_Trigger.RainTotem",
					"Trigger": "spacechase0.SpaceCore_OnItemUsed",
					"Condition": "ITEM_ID Input (O)681",
					"Actions": [
						"IncrementStat {{ModId}}_Stat.RainTotemsUsed 1",
						"Spiderbuttons.BETAS_Message \"{{i18n: i18n_String.RainTotemUsed}}\" true",
						"Spiderbuttons.BETAS_PlaySound rainsound true",
						"Spiderbuttons.BETAS_WeatherForTomorrow default Rain",
						//"spacechase0.SpaceCore_PlayEvent eventid"
					],
					"MarkActionApplied": false,
				},
				// Storm Totem
				"{{ModId}}_Trigger.StormTotem": {
					"Id": "{{ModId}}_Trigger.StormTotem",
					"Trigger": "spacechase0.SpaceCore_OnItemUsed",
					"Condition": "ITEM_ID Input (O){{ModId}}_Item.StormTotem",
					"Actions": [
						"Spiderbuttons.BETAS_Lightning",
						"IncrementStat {{ModId}}_Stat.StormTotemsUsed 1",
						"Spiderbuttons.BETAS_Message \"{{i18n: i18n_String.StormTotemUsed}}\" true",
						"Spiderbuttons.BETAS_WeatherForTomorrow default Storm"
					], // TODO: SpaceCore spawning when ready
					"MarkActionApplied": false,
				},
				// Sun Totem
				"{{ModId}}_Trigger.SunTotem": {
					"Id": "{{ModId}}_Trigger.SunTotem",
					"Trigger": "spacechase0.SpaceCore_OnItemUsed",
					"Condition": "ITEM_ID Input (O){{ModId}}_Item.SunTotem",
					"Actions": [
						"IncrementStat {{ModId}}_Stat.SunTotemsUsed 1",
						"Spiderbuttons.BETAS_Message \"{{i18n: i18n_String.SunTotemUsed}}\" true",
						"Spiderbuttons.BETAS_WeatherForTomorrow default Sun"
					], // TODO: SpaceCore spawning when ready
					"MarkActionApplied": false,
				},
				// Snow Totem
				"{{ModId}}_Trigger.SnowTotem": {
					"Id": "{{ModId}}_Trigger.SnowTotem",
					"Trigger": "spacechase0.SpaceCore_OnItemUsed",
					"Condition": "ITEM_ID Input (O){{ModId}}_Item.SnowTotem",
					"Actions": [
						"IncrementStat {{ModId}}_Stat.SnowTotemsUsed 1",
						"Spiderbuttons.BETAS_Message \"{{i18n: i18n_String.SnowTotemUsed}}\" true",
						"Spiderbuttons.BETAS_WeatherForTomorrow default Snow"
					], // TODO: SpaceCore spawning when ready
					"MarkActionApplied": false,
				},
				// Wind Totem
				"{{ModId}}_Trigger.WindTotem": {
					"Id": "{{ModId}}_Trigger.WindTotem",
					"Trigger": "spacechase0.SpaceCore_OnItemUsed",
					"Condition": "ITEM_ID Input (O){{ModId}}_Item.WindTotem",
					"Actions": [
						"IncrementStat {{ModId}}_Stat.WindTotemsUsed 1",
						"Spiderbuttons.BETAS_Message \"{{i18n: i18n_String.WindTotemUsed}}\" true",
						"Spiderbuttons.BETAS_WeatherForTomorrow default Wind"
					], // TODO: SpaceCore spawning when ready
					"MarkActionApplied": false,
				},
				// --- Recipe Unlocks ---
				"{{ModId}}_Trigger.StormTotemUnlock": {
					"Id": "{{ModId}}_Trigger.StormTotemUnlock",
					"Trigger": "DayStarted",
					"Condition": "PLAYER_STAT current {{ModId}}_Stat.RainTotemsUsed 5",
					"Actions": [
						"MarkCraftingRecipeKnown current {{ModId}}_Recipe.StormTotem",
						"Spiderbuttons.BETAS_Message \"{{i18n: i18n_String.StormTotemUnlock}}\" true"
					]
				},
			}
		},
	]
}